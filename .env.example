# Database
# Local: postgresql+asyncpg://workout:workout@localhost:5432/workout_tracker
# Supabase: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://workout:workout@localhost:5432/workout_tracker

# Security
TOKEN_ENCRYPTION_KEY=  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Whoop (https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/auth/whoop/callback
WHOOP_WEBHOOK_SECRET=

# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback
STRAVA_VERIFY_TOKEN=  # Generate: python -c "import secrets; print(secrets.token_urlsafe(16))"

# Wahoo (https://developers.wahooligan.com/applications/new)
WAHOO_CLIENT_ID=
WAHOO_CLIENT_SECRET=
WAHOO_REDIRECT_URI=http://localhost:8000/auth/wahoo/callback

# SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=workouts@yourapp.com

# App
# Local: http://localhost:8000
# Production: https://your-app.up.railway.app
APP_BASE_URL=http://localhost:8000
